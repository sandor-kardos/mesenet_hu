# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Override the default pipeline model (claude-haiku-4-5)
# PIPELINE_CLAUDE_MODEL=claude-haiku-4-5

# ─── Google Gemini (image generation) ────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_IMAGE_MODEL=imagen-3.0-generate-001

# ─── Google Cloud Vision (OCR) ───────────────────────────────────────────────
# Path to your service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ─── Google Custom Search (scout.py) ─────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_programmable_search_engine_id

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET=mesenet-illustrations

# ─── Neon Postgres ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# ─── WordPress REST API ──────────────────────────────────────────────────────
WP_BASE_URL=https://api.mesenet.hu
WP_USERNAME=your_wordpress_username
WP_APP_PASSWORD=your_wordpress_application_password

# ─── Poppler (Windows only — required by pdf2image) ──────────────────────────
# POPPLER_PATH=C:\Users\you\AppData\Local\Microsoft\WinGet\Packages\oschwartz10612.Poppler_...\Library\bin

# ─── Pipeline tunables ────────────────────────────────────────────────────────
# Confidence threshold below which OCR falls back to tesseract (default: 0.70)
# OCR_CONFIDENCE_THRESHOLD=0.70

# Temp directory for ingest.py PDF/R2 downloads
# INGEST_TMP_DIR=/tmp/mesenet_pages

# Domain excluded from scout.py hit detection
# SCOUT_OWN_DOMAIN=mesenet.hu
